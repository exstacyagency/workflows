# =============================================================================
# CORE
# =============================================================================

# PostgreSQL connection string (Neon, Supabase, Railway, or self-hosted)
DATABASE_URL=

# NextAuth session signing secret — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# Full public URL of the app
NEXTAUTH_URL=https://app.yourdomain.com

# Same as NEXTAUTH_URL
APP_URL=https://app.yourdomain.com

# JWT signing secret — generate with: openssl rand -base64 32
JWT_SECRET=

# Runtime mode — set to "beta" for production use
MODE=beta

# =============================================================================
# ANTHROPIC
# =============================================================================

ANTHROPIC_API_KEY=

# Optional model overrides
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
# ANTHROPIC_HAIKU_MODEL=claude-3-haiku-20240307
# ANTHROPIC_QUALITY_MODEL=claude-3-5-sonnet-20241022
# ANTHROPIC_TIMEOUT_MS=90000
# ANTHROPIC_RETRIES=3

# =============================================================================
# AWS S3
# =============================================================================

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Main media bucket (videos, images, frames)
AWS_S3_BUCKET=

# Product setup references bucket
AWS_S3_BUCKET_PRODUCT_SETUP=

# Optional: custom S3-compatible endpoint (Cloudflare R2, MinIO, etc.)
# AWS_S3_ENDPOINT=
# AWS_S3_ENDPOINT_PRODUCT_SETUP=

# =============================================================================
# KIE.AI (VIDEO GENERATION)
# =============================================================================

KIE_API_KEY=
KIE_API_BASE_URL=
KIE_CREATE_PATH=
KIE_STATUS_PATH=

# Set to "true" to enable real video generation (charges credits)
KIE_LIVE_MODE=false

# Optional tuning
# KIE_POLL_INTERVAL_MS=5000
# KIE_HTTP_TIMEOUT_MS=120000

# =============================================================================
# FAL.AI (MERGE + UPSCALE)
# =============================================================================

FAL_API_KEY=

# =============================================================================
# STRIPE
# =============================================================================

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Stripe Price IDs for subscription plans
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_SCALE=

# =============================================================================
# APIFY (RESEARCH — AD COLLECTION + AMAZON REVIEWS)
# =============================================================================

APIFY_API_TOKEN=

# Optional
# APIFY_DATASET_ID=
# APIFY_DEFAULT_INDUSTRY_CODE=

# =============================================================================
# ASSEMBLYAI (AD TRANSCRIPT EXTRACTION)
# =============================================================================

ASSEMBLYAI_API_KEY=

# =============================================================================
# GOOGLE CLOUD VISION (AD OCR)
# =============================================================================

GOOGLE_CLOUD_VISION_API_KEY=

# =============================================================================
# REDDIT SCRAPER (OPTIONAL — improves research quality)
# Self-hosted service that enables targeted subreddit scraping.
# Without this, Reddit research falls back to sitewide Apify search.
# =============================================================================

# REDDIT_SCRAPER_URL=http://localhost:5001
# REDDIT_USER_AGENT=

# =============================================================================
# ELEVENLABS (OPTIONAL — CHARACTER VOICE)
# =============================================================================

# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=
# ELEVENLABS_STS_MODEL=
# ELEVENLABS_OUTPUT_FORMAT=

# =============================================================================
# FFMPEG (OPTIONAL — VIDEO TRIMMING)
# Required for trim-before-merge in the video editor.
# =============================================================================

# FFMPEG_PATH=/usr/bin/ffmpeg

# =============================================================================
# QUEUE (OPTIONAL)
# =============================================================================

# Queue backend: "db" (default, no extra infra) or "redis"
QUEUE_BACKEND=db

# Required only if QUEUE_BACKEND=redis
# REDIS_URL=

# =============================================================================
# WORKER TUNING (OPTIONAL)
# =============================================================================

# WORKER_JOB_MAX_RUNTIME_MS=300000
# JOB_RUNNING_STALE_MS=600000
# MAX_JOB_ATTEMPTS=3
# VIDEO_GENERATION_JOB_MAX_RUNTIME_MS=1800000

# =============================================================================
# AUTH TUNING (OPTIONAL)
# =============================================================================

# AUTH_MAX_ATTEMPTS=5
# AUTH_WINDOW_MS=900000
# AUTH_LOCKOUT_MS=1800000

# =============================================================================
# ADMIN (OPTIONAL)
# =============================================================================

# Token required for admin-only API routes (dead-letter management, logs)
# DEBUG_ADMIN_TOKEN=

# =============================================================================
# BOOTSTRAP (OPTIONAL — for initial setup seeding)
# =============================================================================

# BOOTSTRAP_ADMIN_EMAIL=
# BOOTSTRAP_ADMIN_PASSWORD=
# BOOTSTRAP_PROJECT_NAME=
# BOOTSTRAP_PROJECT_ID=
# BOOTSTRAP_SEED_PROJECT=false
